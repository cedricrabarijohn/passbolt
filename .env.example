# =============================================================================
# Passbolt Local — Environment Variables
# =============================================================================
# Copy this file to .env and edit as needed:
#   cp .env.example .env
# =============================================================================

# --- Database ---
MYSQL_ROOT_PASSWORD=root_p@ssw0rd
MYSQL_DATABASE=passbolt
MYSQL_USER=passbolt
MYSQL_PASSWORD=P@ssbolt!2024

# --- Passbolt App ---
# Use https://passbolt.local:8443 for local dev (add to /etc/hosts)
# Or use https://localhost if you prefer
APP_FULL_BASE_URL=https://passbolt.local:8443

# --- Ports ---
HTTP_PORT=80
HTTPS_PORT=443

# --- SMTP (optional — for email notifications) ---
EMAIL_FROM=noreply@passbolt.local
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_TLS=true

# --- Admin user (used by `make create-admin`) ---
ADMIN_EMAIL=admin@passbolt.local
ADMIN_FIRST=Tsanta
ADMIN_LAST=Admin
